    "# These two are equivalent:\n",
    "\n",
    "# Manual way\n",
    "X_test_scaled     = scaler.transform(X_test)\n",
    "X_test_normalized = normalizer.transform(X_test_scaled)\n",
    "y_pred_manual     = svm.predict(X_test_normalized)\n",
    "\n",
    "# Pipeline way (same result)\n",
